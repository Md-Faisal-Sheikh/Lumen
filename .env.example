# ─────────────────────────────────────────────────────────────
# Lumen server configuration  (copy this file to  server/.env)
# ─────────────────────────────────────────────────────────────

# HTTP + WebSocket port for the server
PORT=4000

# Where the client runs in dev (used for CORS)
CLIENT_ORIGIN=http://localhost:5173

# Secret used to sign auth tokens — CHANGE THIS in production
JWT_SECRET=change-this-to-a-long-random-string

# SQLite by default (no database server needed).
# To use Postgres instead, change the datasource provider in
# server/prisma/schema.prisma to "postgresql" and set a URL here.
DATABASE_URL="file:./dev.db"

# ── AI build engine ─────────────────────────────────────────
# Choose ONE free provider:  groq | gemini | ollama
AI_PROVIDER=groq

# Groq  — free API key from https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini — free API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Ollama — fully local, no key. Install from https://ollama.com
#   then:  ollama pull qwen2.5-coder:7b
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b
